# Pages configuration — copy to .env and fill in.
# On the iMac, deploy/bootstrap.sh stitches values in from ~/homelab/.env
# (the source-of-truth for tyflix family secrets).

# --- Brand (one config change to rebrand) ---
NEXT_PUBLIC_PAGES_NAME=Pages
NEXT_PUBLIC_PAGES_TAGLINE=Books and audiobooks, all yours
NEXT_PUBLIC_PAGES_DOMAIN=pages.tyflix.net

# --- Postgres ---
DATABASE_URL=postgres://pages:pages-local-dev@postgres:5432/pages
POSTGRES_USER=pages
POSTGRES_PASSWORD=pages-local-dev
POSTGRES_DB=pages

# --- Engine ---
PAGES_ENGINE_URL=http://pages-engine:8003
PAGES_ENGINE_INTERNAL_URL=http://localhost:8003

# --- Auth (shared family cookie at .tyflix.net) ---
# IMPORTANT: this is the same secret used by genome / reel / karaoke
# so a single sign-in propagates across the family.
TYFLIX_AUTH_JWT_SECRET=replace-with-shared-family-secret
TYFLIX_AUTH_COOKIE_NAME=tyflix_session
TYFLIX_AUTH_COOKIE_DOMAIN=.tyflix.net
PAGES_OWNER_FIRST_NAME=tyler

# --- Library locations (mounted from the iMac into the engine container) ---
# These should already be the same paths Kavita + Audiobookshelf scan today.
PAGES_EBOOK_ROOTS=/library/ebooks
PAGES_AUDIOBOOK_ROOTS=/library/audiobooks

# --- Metadata enrichment ---
GOOGLE_BOOKS_API_KEY=
OPEN_LIBRARY_USER_AGENT=Pages/1.0 (pages.tyflix.net; tylerheon@gmail.com)
GOODREADS_SCRAPE_ENABLED=true   # opt-in unofficial fallback

# --- Request feature ---
READARR_URL=http://host.docker.internal:8787
READARR_API_KEY=
READARR_BOOK_ROOT=/library/ebooks
READARR_AUDIOBOOK_DOWNLOADER_URL=
READARR_AUDIOBOOK_DOWNLOADER_KEY=

# --- Existing self-hosted apps to import from + cross-link ---
KAVITA_URL=http://host.docker.internal:5000
KAVITA_API_KEY=
ABS_URL=http://host.docker.internal:13378
ABS_API_KEY=

# --- Cross-app deep links (used by smart features in Phase 8) ---
REEL_URL=https://reel.tyflix.net
GENOME_URL=https://genome.tyflix.net
KARAOKE_URL=https://karaoke.tyflix.net
TYFLIX_PORTAL_URL=https://tyflix.net

# --- E-reader export ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=pages@tyflix.net

# --- Music Assistant integration (optional, AirPlay routing for audiobooks) ---
MUSIC_ASSISTANT_URL=http://host.docker.internal:8095
MUSIC_ASSISTANT_TOKEN=

# --- Calibre conversion ---
CALIBRE_BIN=/usr/bin/ebook-convert
CONVERT_TIMEOUT_S=120

# --- Logging ---
LOG_LEVEL=info
